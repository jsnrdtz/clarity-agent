# HTTP server port
PORT=3000

# Internal project score cache: 10 minutes
CLARITY_CACHE_TTL_MS=600000

# Trust reverse-proxy client IP headers for per-client rate limiting.
# Enable only when the API runs behind a trusted proxy such as Railway.
CLARITY_TRUST_PROXY=false

# GitHub personal access token.
# Never commit the real token.
GITHUB_TOKEN=

# Bearer token protecting the administrative refresh endpoint.
# Use a random secret of at least 32 characters.
CLARITY_REFRESH_TOKEN=

# Directory for last successful agent evaluations
CLARITY_SNAPSHOT_DIR=data/snapshots

# Maximum snapshot age used by ranking and comparison: 6 hours
CLARITY_RANKING_SNAPSHOT_MAX_AGE_MS=21600000

# Atomic lock preventing overlapping snapshot refresh jobs
CLARITY_REFRESH_LOCK_PATH=data/refresh.lock

# Remove an abandoned refresh lock after 30 minutes
CLARITY_REFRESH_LOCK_STALE_MS=1800000

# Maximum duration of one live GitHub evaluation
CLARITY_LIVE_EVALUATION_TIMEOUT_MS=10000

# Bankr official website discovery
CLARITY_BANKR_WEBSITE_TIMEOUT_MS=8000
CLARITY_BANKR_WEBSITE_MAX_BYTES=1000000
CLARITY_BANKR_WEBSITE_MAX_REDIRECTS=3

# Published Candidate Review report
CLARITY_CANDIDATE_UPLOAD_TOKEN=
CLARITY_CANDIDATE_UPLOAD_MAX_BYTES=5242880
CLARITY_BANKR_PUBLISHED_REPORT_PATH=data/candidates/published-bankr.json

# Manual candidate review
CLARITY_CANDIDATE_REVIEW_TOKEN=
CLARITY_CANDIDATE_REVIEW_PATH=data/candidates/bankr-reviews.json
