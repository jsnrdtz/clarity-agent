# HTTP server port
PORT=3000

# Internal project score cache: 10 minutes
CLARITY_CACHE_TTL_MS=600000

# GitHub personal access token.
# Never commit the real token.
GITHUB_TOKEN=

# Directory for last successful agent evaluations
CLARITY_SNAPSHOT_DIR=data/snapshots

# Maximum snapshot age used by ranking and comparison: 6 hours
CLARITY_RANKING_SNAPSHOT_MAX_AGE_MS=21600000
